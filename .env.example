# ─── Supabase ───────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Anthropic (Haiku scoring + Sonnet extraction) ──────────
ANTHROPIC_API_KEY=

# ─── OpenAI (embeddings) ────────────────────────────────────
OPENAI_API_KEY=

# ─── IMAP (dev/test only — prod creds come from ingestion_sources.config) ───
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX
IMAP_POLL_INTERVAL_MS=300000

# ─── Zendesk (dev/test only — prod creds come from ingestion_sources.config) ───
ZENDESK_SUBDOMAIN=
ZENDESK_EMAIL=
ZENDESK_API_TOKEN=
ZENDESK_POLL_INTERVAL_MS=300000

# ─── Credential encryption (KMS key for ingestion_sources.config) ───
# 32-byte key, base64-encoded. Generate: openssl rand -base64 32
CONFIG_ENCRYPTION_KEY=

# ─── App ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Allowed browser origin(s) for CORS, comma-separated. Only needed if the
# frontend is hosted on a DIFFERENT origin than the API. Leave unset for the
# single-service deploy (SPA served same-origin) and for local dev.
WEB_ORIGIN=
# Built SPA directory the API serves (single-service deploy). Default ./public,
# populated by the api build. Override only if serving from elsewhere.
WEB_DIST_DIR=./public

# ─── Frontend (Vite — only VITE_* vars are exposed to the browser) ───
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Single-service deploy: leave EMPTY so the SPA calls /api on its own origin.
# Local dev (separate Vite server): set to http://localhost:3000.
VITE_API_BASE_URL=
