{
  "name": "mailmind",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered knowledge extraction from email, turning support threads into a living knowledge base.",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace apps/api",
    "dev:web": "npm run dev --workspace apps/web",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspace apps/api",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "ingest": "npm run ingest --workspace apps/api --",
    "set-creds": "npm run set-creds --workspace apps/api --"
  },
  "engines": {
    "node": ">=20.12"
  }
}
